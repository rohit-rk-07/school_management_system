<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Student Profile</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:'Poppins',sans-serif;
        }

        body{
            background:#f4f5fb;
        }

        .studentProfileContainer{
            padding:40px 32px;
        }

        .studentProfileHeading{
            font-size:44px;
            font-weight:700;
            color:#111827;
        }

        .studentProfileSubtitle{
            color:#667085;
            margin-top:4px;
            margin-bottom:30px;
        }

        .studentProfileCard{
            background:#ffffff;
            border-radius:32px;
            padding:40px;
            border:1px solid #ececec;
            display:flex;
            gap:40px;
            align-items:center;
        }

        .studentProfileImageSection{
            text-align:center;
        }

        .studentProfileAvatar{
            width:140px;
            height:140px;
            border-radius:50%;
            background:linear-gradient(to right,#675cff,#1dd5c8);
            display:flex;
            align-items:center;
            justify-content:center;
            font-size:52px;
            color:#ffffff;
            font-weight:700;
            margin-bottom:18px;
        }

        .studentProfileBadge{
            display:inline-block;
            padding:8px 16px;
            border-radius:30px;
            background:#dcfff6;
            color:#00c896;
            font-size:14px;
            font-weight:600;
        }

        .studentProfileDetails{
            flex:1;
        }

        .studentProfileName{
            font-size:34px;
            font-weight:700;
            color:#111827;
            margin-bottom:8px;
        }

        .studentProfileClass{
            color:#675cff;
            font-size:18px;
            font-weight:600;
            margin-bottom:30px;
        }

        .studentProfileGrid{
            display:grid;
            grid-template-columns:1fr 1fr;
            gap:24px;
        }

        .studentProfileInfoCard{
            background:#f5f6fb;
            border-radius:20px;
            padding:20px;
        }

        .studentProfileInfoLabel{
            font-size:13px;
            color:#667085;
            margin-bottom:8px;
            font-weight:600;
        }

        .studentProfileInfoValue{
            font-size:18px;
            font-weight:600;
            color:#111827;
        }

    </style>

</head>

<body>
	<jsp:include page="sidebar.jsp"/>
    <div class="studentProfileContainer">

        <h1 class="studentProfileHeading">
            My Profile
        </h1>

        <p class="studentProfileSubtitle">
            View personal and academic information
        </p>

        <div class="studentProfileCard">

            <div class="studentProfileImageSection">

                <div class="studentProfileAvatar">
                    A
                </div>

                <span class="studentProfileBadge">
                    Active Student
                </span>

            </div>

            <div class="studentProfileDetails">

                <h2 class="studentProfileName">
                    Aarav Kumar
                </h2>

                <p class="studentProfileClass">
                    Class 8 - Science
                </p>

                <div class="studentProfileGrid">

                    <div class="studentProfileInfoCard">

                        <p class="studentProfileInfoLabel">
                            ROLL NUMBER
                        </p>

                        <h3 class="studentProfileInfoValue">
                            101
                        </h3>

                    </div>

                    <div class="studentProfileInfoCard">

                        <p class="studentProfileInfoLabel">
                            EMAIL
                        </p>

                        <h3 class="studentProfileInfoValue">
                            aarav@gmail.com
                        </h3>

                    </div>

                    <div class="studentProfileInfoCard">

                        <p class="studentProfileInfoLabel">
                            PHONE
                        </p>

                        <h3 class="studentProfileInfoValue">
                            9876543210
                        </h3>

                    </div>

                    <div class="studentProfileInfoCard">

                        <p class="studentProfileInfoLabel">
                            PARENT NAME
                        </p>

                        <h3 class="studentProfileInfoValue">
                            Mr. Kumar
                        </h3>

                    </div>

                    <div class="studentProfileInfoCard">

                        <p class="studentProfileInfoLabel">
                            DATE OF BIRTH
                        </p>

                        <h3 class="studentProfileInfoValue">
                            12 Aug 2008
                        </h3>

                    </div>

                    <div class="studentProfileInfoCard">

                        <p class="studentProfileInfoLabel">
                            ADDRESS
                        </p>

                        <h3 class="studentProfileInfoValue">
                            Bangalore, India
                        </h3>

                    </div>

                </div>

            </div>

        </div>

    </div>

</body>

</html>