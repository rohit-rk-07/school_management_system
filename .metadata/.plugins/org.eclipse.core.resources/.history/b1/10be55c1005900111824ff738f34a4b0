const loggedInUser = JSON.parse(localStorage.getItem("loggedInUser"));

if (!loggedInUser) {
    window.location.replace("/School_Management_System/login.jsp");
}

window.onload = function () {
    loadStudentProfile();
};

function loadStudentProfile() {
    const studentId = loggedInUser.referenceId;

    fetch(`/School_Management_System/GetStudentProfile?studentId=${studentId}`)
        .then(response => {
            if (!response.ok) throw new Error("Failed to load profile data");
            return response.json();
        })
        .then(data => {
            // 1. Update Profile Main Header Section
            document.querySelector(".studentProfileName").textContent = data.full_name;
            document.querySelector(".studentProfileClass").textContent = data.class_info;
            
            // Extract and set initial for the avatar icon circle
            if(data.full_name && data.full_name !== "N/A") {
                document.querySelector(".studentProfileAvatar").textContent = data.full_name.charAt(0).toUpperCase();
            }

            // 2. Select all grid value components to update them sequentially
            const infoValues = document.querySelectorAll(".studentProfileInfoValue");
            
            // Loop updates mapping exact DOM positions based on your HTML setup:
            // [0]=Roll, [1]=Email, [2]=Phone, [3]=Parent Name, [4]=DOB, [5]=Address
            if (infoValues.length >= 6) {
                infoValues[0].textContent = data.roll_number;
                infoValues[1].textContent = data.email;
                infoValues[2].textContent = data.phone;
                infoValues[3].textContent = data.parent_name;
                infoValues[4].textContent = data.dob;
                infoValues[5].textContent = data.address;
            }
        })
        .catch(error => console.error("Error rendering student profile fields:", error));
}