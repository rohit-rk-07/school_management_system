<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Mark Attendance</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:'Poppins',sans-serif;
        }

        body{
            background:#f4f5fb;
            color:#111827;
            display: flex;
            flex-direction: row;
            justify-content: space-between;
            align-items: start;
        }

        /* =========================
           TOPBAR
        ========================== */

        .attendanceTopbar{
            width:100%;
            background:#ffffff;
            padding:12px 28px;
            display:flex;
            justify-content:space-between;
            align-items:center;
            border-bottom:1px solid #e7e7e7;
        }

        .attendanceTopbarTitle{
            font-size:20px;
            font-weight:600;
        }

        .attendanceTeacherProfile{
            display:flex;
            align-items:center;
            gap:12px;
            background:#f5f6fb;
            padding:10px 14px;
            border-radius:16px;
        }

        .attendanceTeacherAvatar{
            width:42px;
            height:42px;
            border-radius:50%;
            background:linear-gradient(to right,#675cff,#1dd5c8);
            display:flex;
            align-items:center;
            justify-content:center;
            color:#ffffff;
            font-weight:600;
        }

        .attendanceTeacherRole{
            font-size:13px;
            color:#8c8c8c;
        }

        /* =========================
           PAGE CONTAINER
        ========================== */

        .attendancePageContainer{
            padding:0px 12px;
            width: 80%;
        }

        .attendanceMainHeading{
            font-size:44px;
            font-weight:700;
        }

        .attendanceSubtitle{
            color:#667085;
            margin-top:4px;
            margin-bottom:30px;
        }

        /* =========================
           OVERVIEW CARDS
        ========================== */

        .attendanceOverviewGrid{
            display:grid;
            grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
            gap:20px;
            margin-bottom:10px;
        }

        .attendanceOverviewCard{
            background:#ffffff;
            border-radius:28px;
            padding:15px;
            border:1px solid #ececec;
        }

        .attendanceCardLabel{
            font-size:15px;
            font-weight:600;
            color:#667085;
            margin-bottom:0px;
        }

        .attendanceCardValue{
            font-size:42px;
            font-weight:700;
        }

        .attendancePresentText{
            color:#00c896;
        }

        .attendanceAbsentText{
            color:#ff5a5f;
        }

        .attendancePercentageText{
            color:#675cff;
        }

        /* =========================
           FILTER SECTION
        ========================== */

        .attendanceFilterCard{
            background:#ffffff;
            border-radius:30px;
            padding:20px;
            border:1px solid #ececec;
            margin-bottom:20px;
        }

        .attendanceFilterGrid{
            display:grid;
            grid-template-columns:1fr 1fr;
            gap:20px;
        }

        .attendanceFormGroup{
            display:flex;
            flex-direction:column;
        }

        .attendanceFormLabel{
            margin-bottom:10px;
            font-size:14px;
            font-weight:600;
            color:#667085;
        }

        .attendanceInputField,
        .attendanceSelectField{
            width:100%;
            height:54px;
            border:none;
            outline:none;
            background:#f5f6fb;
            border-radius:14px;
            padding:0 18px;
            font-size:16px;
            border:1px solid #e2e5ef;
        }

        /* =========================
           TABLE
        ========================== */

        .attendanceTableCard{
            background:#ffffff;
            border-radius:30px;
            overflow-y: scroll;
            border:1px solid #ececec;
            height: 380px;
        }

        .attendanceTable{
            width:100%;
            border-collapse:collapse;
        }

        .attendanceTable thead{
            background:#f5f6fb;
        }

        .attendanceTable th{
            text-align:left;
            padding:10px 20px;
            font-size:13px;
            color:#98a2b3;
            font-weight:600;
        }

        .attendanceTable td{
            padding:15px;
            font-size: 15px;
            border-top:1px solid #ececec;
        }

        .attendanceStudentName{
            font-weight:600;
        }

        /* =========================
           STATUS BUTTONS
        ========================== */

        .attendanceActionButtons{
            display:flex;
            gap:10px;
        }

        .attendancePresentButton,
        .attendanceAbsentButton{
            border:none;
            padding:10px 16px;
            border-radius:12px;
            cursor:pointer;
            font-weight:600;
            transition:0.3s;
        }

        .attendancePresentButton{
            background:#dcfff6;
            color:#00c896;
        }

        .attendanceAbsentButton{
            background:#ffe3e3;
            color:#ff5a5f;
        }

        .attendancePresentButton.active{
            background:#00c896;
            color:#ffffff;
        }

        .attendanceAbsentButton.active{
            background:#ff5a5f;
            color:#ffffff;
        }

        /* =========================
           SAVE BUTTON
        ========================== */

        .attendanceSaveContainer{
            margin-top:5px;
            display:flex;
            justify-content:flex-end;
        }

        .attendanceSaveButton{
            border:none;
            background:#5c4ef7;
            color:#ffffff;
            padding:14px 28px;
            border-radius:14px;
            font-size:16px;
            font-weight:600;
            cursor:pointer;
            box-shadow:0 10px 20px rgba(92,78,247,0.2);
        }

        @media(max-width:900px){

            .attendanceFilterGrid{
                grid-template-columns:1fr;
            }

            .attendanceTable{
                display:block;
                overflow-x:auto;
            }

        }
        
        .attendanceFilterSection{
    display:flex;
    gap:20px;
    margin-bottom:24px;
    background:#ffffff;
    padding:24px;
    border-radius:24px;
    border:1px solid #ececec;
}

.attendanceFilterInput{
    flex:1;
    height:56px;
    border:none;
    outline:none;
    background:#f5f6fb;
    border-radius:16px;
    padding:0 18px;
    font-size:16px;
    font-weight:500;
    color:#111827;
    border:1px solid #e2e5ef;
    transition:0.3s;
}

.attendanceFilterInput:focus{
    border-color:#675cff;
    box-shadow:0 0 0 4px rgba(103,92,255,0.12);
    background:#ffffff;
}

.attendanceFilterInput::placeholder{
    color:#98a2b3;
}

    </style>

</head>

<body>
    <jsp:include page="sidebar.jsp"/>
    <!-- PAGE -->
    <div class="attendancePageContainer">
    <div class="attendanceTopbar">
        <h2 class="attendanceTopbarTitle"> Mark Attendance </h2>
        <div class="attendanceTeacherProfile">
            <div class="attendanceTeacherAvatar"> T </div>
            <div>
                <h4>Teacher</h4>
                <p class="attendanceTeacherRole"> Science Department </p>
            </div>
        </div>
    </div>
    
        <h1 class="attendanceMainHeading">  Attendance Management </h1>
        <p class="attendanceSubtitle"> Mark daily attendance for students </p>
        <!-- OVERVIEW -->

        <div class="attendanceOverviewGrid">
            <div class="attendanceOverviewCard">
                <p class="attendanceCardLabel"> TOTAL STUDENTS </p>
                <h2 class="attendanceCardValue" id="totalStudents"> 0 </h2>
            </div>

            <div class="attendanceOverviewCard">
                <p class="attendanceCardLabel"> PRESENT </p>
                <h2 class="attendanceCardValue attendancePresentText" id="presentCount"> 0 </h2>
            </div>

            <div class="attendanceOverviewCard">
                <p class="attendanceCardLabel"> ABSENT</p>
                <h2 class="attendanceCardValue attendanceAbsentText" id="absentCount"> 0</h2>
            </div>
        </div>
        
        <!-- =========================
     DATE + CLASS INPUTS
========================= -->

<div class="attendanceFilterSection">
    <input type="date"id="attendanceDate" class="attendanceFilterInput">
    <select id="classId" class="attendanceFilterInput">

    <option value="">Select Class</option>

</select>
</div>

<!-- =========================
     TABLE
========================= -->

<div class="attendanceTableCard">
    <table class="attendanceTable">
        <thead>
            <tr>
                <th>ROLL NO</th>
                <th>FIRST NAME</th>
                <th>MIDDLE NAME</th>
                <th>LAST NAME</th>
                <th>GENDER</th>
                <th>STATUS</th>
            </tr>
        </thead>
        <tbody id="attendanceTableBody">
            <!-- ROW 1 -->
            <tr>
                <td colspan=6>Select Class</td>
            </tr>
        </tbody>
    </table>
</div>
<!-- SAVE BUTTON -->
<div class="attendanceSaveContainer">
    <button class="attendanceSaveButton"id="saveAttendanceButton">Save Attendance</button>
</div>

    </div>
    <script type="text/javascript" src="attendance.js"></script>
</body>
</html>

