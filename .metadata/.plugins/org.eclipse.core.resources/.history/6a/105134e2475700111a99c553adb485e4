<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Login Page</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:'Poppins',sans-serif;
        }

        body{
            width:100%;
            height:100vh;
            background:#f4f5fb;
            display:flex;
            justify-content:center;
            align-items:center;
            overflow:hidden;
        }

        /* =========================
           LOGIN CARD
        ========================== */

        .loginPageCard{
            width:430px;
            background:#ffffff;
            border-radius:34px;
            padding:42px;
            border:1px solid #ececec;
            box-shadow:0 20px 40px rgba(0,0,0,0.06);
            position:relative;
            overflow:hidden;
        }

        .loginPageCard::before{
            content:"";
            position:absolute;
            top:0;
            left:0;
            width:100%;
            height:6px;
            background:linear-gradient(
                to right,
                #675cff,
                #22d3c5
            );
        }

        /* =========================
           HEADER
        ========================== */

        .loginPageHeader{
            text-align:center;
            margin-bottom:34px;
        }

        .loginPageLogo{
            width:80px;
            height:80px;
            border-radius:24px;
            background:linear-gradient(
                to right,
                #675cff,
                #22d3c5
            );
            display:flex;
            justify-content:center;
            align-items:center;
            margin:0 auto 20px;
            color:#ffffff;
            font-size:32px;
            font-weight:700;
            box-shadow:0 12px 24px rgba(103,92,255,0.25);
        }

        .loginPageTitle{
            font-size:36px;
            font-weight:700;
            color:#111827;
            margin-bottom:8px;
        }

        .loginPageSubtitle{
            color:#667085;
            font-size:15px;
        }

        /* =========================
           FORM
        ========================== */

        .loginPageForm{
            display:flex;
            flex-direction:column;
            gap:22px;
        }

        .loginPageInputGroup{
            display:flex;
            flex-direction:column;
        }

        .loginPageInputLabel{
            margin-bottom:10px;
            font-size:14px;
            font-weight:600;
            color:#667085;
        }

        .loginPageInputField{
            width:100%;
            height:58px;
            border:none;
            outline:none;
            background:#f5f6fb;
            border-radius:16px;
            padding:0 18px;
            font-size:16px;
            border:1px solid #e2e5ef;
            color:#111827;
        }

        .loginPageInputField:focus{
            border-color:#675cff;
        }

        /* =========================
           PASSWORD FIELD
        ========================== */

        .loginPagePasswordWrapper{
            position:relative;
        }

        .loginPagePasswordInput{
            width:100%;
            height:58px;
            border:none;
            outline:none;
            background:#f5f6fb;
            border-radius:16px;
            padding:0 55px 0 18px;
            font-size:16px;
            border:1px solid #e2e5ef;
            color:#111827;
        }

        .loginPagePasswordInput:focus{
            border-color:#675cff;
        }

        .loginPagePasswordToggle{
            position:absolute;
            right:18px;
            top:50%;
            transform:translateY(-50%);
            cursor:pointer;
            font-size:20px;
            color:#667085;
            user-select:none;
        }

        /* =========================
           OPTIONS
        ========================== */

        .loginPageOptions{
            display:flex;
            justify-content:space-between;
            align-items:center;
            margin-top:-4px;
        }

        .loginPageRememberMe{
            display:flex;
            align-items:center;
            gap:8px;
            color:#667085;
            font-size:14px;
        }

        .loginPageForgotPassword{
            text-decoration:none;
            color:#675cff;
            font-size:14px;
            font-weight:600;
        }

        /* =========================
           LOGIN BUTTON
        ========================== */

        .loginPageButton{
            width:100%;
            height:58px;
            border:none;
            border-radius:16px;
            background:linear-gradient(
                to right,
                #675cff,
                #5b4df7
            );
            color:#ffffff;
            font-size:17px;
            font-weight:600;
            cursor:pointer;
            transition:0.3s;
            box-shadow:0 12px 24px rgba(103,92,255,0.25);
        }

        .loginPageButton:hover{
            transform:translateY(-2px);
        }

        /* =========================
           FOOTER
        ========================== */

        .loginPageFooter{
            margin-top:28px;
            text-align:center;
            color:#667085;
            font-size:14px;
        }

        .loginPageFooter a{
            color:#675cff;
            text-decoration:none;
            font-weight:600;
        }

        /* =========================
           RESPONSIVE
        ========================== */

        @media(max-width:500px){

            .loginPageCard{
                width:92%;
                padding:30px;
            }

            .loginPageTitle{
                font-size:30px;
            }

        }

    </style>

</head>

<body>

    <!-- =========================
         LOGIN CARD
    ========================== -->

    <div class="loginPageCard">

        <!-- HEADER -->

        <div class="loginPageHeader">

            <div class="loginPageLogo">
                S
            </div>

            <h1 class="loginPageTitle">
                Welcome Back
            </h1>

            <p class="loginPageSubtitle">
                Login to continue to your dashboard
            </p>

        </div>

        <!-- FORM -->

        <form class="loginPageForm">

            <!-- EMAIL -->

            <div class="loginPageInputGroup">

                <label class="loginPageInputLabel">
                    EMAIL ADDRESS
                </label>

                <input 
                    type="email"
                    placeholder="Enter your email"
                    class="loginPageInputField"
                    id="loginEmail"
                >

            </div>

            <!-- PASSWORD -->

            <div class="loginPageInputGroup">

                <label class="loginPageInputLabel">
                    PASSWORD
                </label>

                <div class="loginPagePasswordWrapper">

                    <input 
                        type="password"
                        placeholder="Enter your password"
                        class="loginPagePasswordInput"
                        id="loginPassword"
                    >

                    <span 
                        class="loginPagePasswordToggle"
                        id="togglePasswordButton"
                    >
                        <i class="fa-solid fa-eye"></i>
                    </span>

                </div>

            </div>

       

            <!-- BUTTON -->

            <button 
                type="submit"
                class="loginPageButton"
            >
                Login
            </button>

        </form>

        <!-- FOOTER -->

        <div class="loginPageFooter">

            Don't have an account?

            <a href="#">
                Contact Admin
            </a>

        </div>

    </div>

    <!-- =========================
         JAVASCRIPT
    ========================== -->

    <script>

        const togglePasswordButton =
            document.getElementById(
                "togglePasswordButton"
            );

        const loginPassword =
            document.getElementById(
                "loginPassword"
            );

        togglePasswordButton.addEventListener(
            "click",
            () => {

                if(
                    loginPassword.type === "password"
                ){

                    loginPassword.type = "text";

                    togglePasswordButton.innerText =
                        "🙈";

                }

                else{

                    loginPassword.type = "password";

                    togglePasswordButton.innerText =
                        "<i class="fa-solid fa-eye"></i>";

                }

            }
        );

    </script>

</body>

