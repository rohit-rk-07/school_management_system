<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Classes Management UI</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:'Poppins',sans-serif;
        }

        body{
            background:#f4f5fb;
            color:#111827;
            display: flex;
            flex-direction: row;
            justify-content: space-between;
            align-items: start;
            
        }

        /* =========================
           TOPBAR
        ========================== */

        .classPageTopbar{
            width:100%;
            background:#ffffff;
            padding:12px 28px;
            display:flex;
            justify-content:space-between;
            align-items:center;
            border-bottom:1px solid #e7e7e7;
        }

        .classPageHeading{
            font-size:20px;
            font-weight:600;
        }

        .classAdminProfileCard{
            display:flex;
            align-items:center;
            gap:12px;
            background:#f5f6fb;
            padding:10px 14px;
            border-radius:16px;
        }

        .classAdminAvatar{
            width:42px;
            height:42px;
            border-radius:50%;
            background:linear-gradient(to right,#675cff,#1dd5c8);
            display:flex;
            align-items:center;
            justify-content:center;
            color:#ffffff;
            font-weight:600;
        }

        .classAdminRole{
            font-size:13px;
            color:#8c8c8c;
        }

        /* =========================
           PAGE CONTAINER
        ========================== */

        .classManagementPageContainer{
            padding:10px 12px;
            width: 80%;
        }

        .classManagementHeaderSection{
            display:flex;
            justify-content:space-between;
            align-items:center;
            margin-bottom:30px;
        }

        .classManagementTitle{
            font-size:40px;
            font-weight:700;
        }

        .classManagementSubtitle{
            color:#667085;
            margin-top:4px;
        }

        /* =========================
           CREATE BUTTON
        ========================== */

        .createClassButton{
            border:none;
            background:#5c4ef7;
            color:#ffffff;
            padding:10px 28px;
            border-radius:14px;
            font-size:16px;
            font-weight:600;
            cursor:pointer;
            transition:0.3s;
            box-shadow:0 10px 20px rgba(92,78,247,0.2);
        }

        .createClassButton:hover{
            background:#4f41f0;
        }

        /* =========================
           CLASS GRID
        ========================== */

        .classCardsGrid{
            display:grid;
            grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
            gap:20px;
            overflow-y: scroll;
            height: 550px;
        }

        /* =========================
           CLASS CARD
        ========================== */

        .classCardContainer{
        	width: 271px;
        	height: 200px;
            background:#ffffff;
            border-radius:28px;
            padding:20px;
            position:relative;
            overflow:hidden;
            border:1px solid #ececec;
        }

        .classCardTopDecoration{
            position:absolute;
            top:0;
            right:0;
            width:80px;
            height:60px;
            background:#c9c1ff;
            border-bottom-left-radius:40px;
        }

        .classStudentCountBadge{
            position:absolute;
            top:24px;
            right:26px;
            background:#d8fff6;
            color:#00bfa5;
            padding:6px 14px;
            border-radius:30px;
            font-size:14px;
            font-weight:600;
        }

        .classCardTitle{
            font-size:20px;
            font-weight:700;
            margin-bottom:4px;
        }

        .classCardSectionText{
            color:#8c8c8c;
            margin-bottom:20px;
        }

        .classCardInfo{
            margin-bottom:0px;
            color:#475467;
            font-size:16px;
        }

        .classCardDivider{
            width:100%;
            height:1px;
            background:#ececec;
            margin:4px 16px;
        }

        .classDeleteButton{
            width:42px;
            height:42px;
            border:none;
            border-radius:12px;
            background:#f5f6fb;
            cursor:pointer;
            font-size:18px;
        }

        /* =========================
           MODAL OVERLAY
        ========================== */

        .classModalOverlay{
            position:fixed;
            inset:0;
            background:rgba(0,0,0,0.45);
            backdrop-filter:blur(6px);
            display:none;
            align-items:center;
            justify-content:center;
            z-index:999;
        }

        .classModalOverlay.active{
            display:flex;
        }

        /* =========================
           MODAL CONTAINER
        ========================== */

        .classModalContainer{
            width:700px;
            background:#ffffff;
            border-radius:34px;
            padding:34px;
            box-shadow:0 20px 50px rgba(0,0,0,0.18);
            animation:classPopupAnimation 0.3s ease;
        }

        @keyframes classPopupAnimation{

            from{
                transform:scale(0.9);
                opacity:0;
            }

            to{
                transform:scale(1);
                opacity:1;
            }

        }

        /* =========================
           MODAL HEADER
        ========================== */

        .classModalHeader{
            display:flex;
            justify-content:space-between;
            align-items:center;
            margin-bottom:30px;
        }

        .classModalTitle{
            font-size:34px;
            font-weight:700;
        }

        .classCloseModalButton{
            width:44px;
            height:44px;
            border:none;
            border-radius:12px;
            background:#f5f6fb;
            font-size:22px;
            cursor:pointer;
        }

        /* =========================
           FORM GRID
        ========================== */

        .classFormGrid{
            display:grid;
            grid-template-columns:1fr 1fr;
            gap:24px;
        }

        .classFormGroup{
            display:flex;
            flex-direction:column;
        }

        .classFormLabel{
            margin-bottom:10px;
            font-size:15px;
            font-weight:600;
            color:#667085;
            letter-spacing:0.5px;
        }

        .classFormInput{
            height:56px;
            border:none;
            outline:none;
            background:#f5f6fb;
            border-radius:14px;
            padding:0 18px;
            font-size:17px;
            border:1px solid #e2e5ef;
        }

        /* =========================
           MODAL FOOTER
        ========================== */

        .classModalFooter{
            display:flex;
            justify-content:flex-end;
            gap:18px;
            margin-top:34px;
        }

        .classCancelButton{
            border:none;
            background:#eef1f6;
            color:#667085;
            padding:14px 28px;
            border-radius:14px;
            font-size:17px;
            font-weight:600;
            cursor:pointer;
        }

        .classSaveButton{
            border:none;
            background:#5c4ef7;
            color:#ffffff;
            padding:14px 28px;
            border-radius:14px;
            font-size:17px;
            font-weight:600;
            cursor:pointer;
            box-shadow:0 10px 20px rgba(92,78,247,0.2);
        }

        /* =========================
           RESPONSIVE
        ========================== */

        @media(max-width:768px){

            .classManagementHeaderSection{
                flex-direction:column;
                align-items:flex-start;
                gap:20px;
            }

            .classFormGrid{
                grid-template-columns:1fr;
            }

            .classModalContainer{
                width:95%;
                padding:24px;
            }

        }

    </style>

</head>

<body>

    <!-- =========================
         TOPBAR
    ========================== -->

	<jsp:include page="sidebar.jsp" />


    <!-- =========================
         PAGE CONTENT
    ========================== -->

    <div class="classManagementPageContainer">
    
    <div class="classPageTopbar">

        <h2 class="classPageHeading">
            Classes
        </h2>

        <div class="classAdminProfileCard">

            <div class="classAdminAvatar">
                A
            </div>

            <div>
                <h4>Admin</h4>
                <p class="classAdminRole">
                    Super Admin
                </p>
            </div>

        </div>

    </div>

        <!-- HEADER -->

        <div class="classManagementHeaderSection">

            <div>

                <h1 class="classManagementTitle">
                    Classes
                </h1>

                <p class="classManagementSubtitle">
                    Create and manage class rooms
                </p>

            </div>

            <button 
                class="createClassButton"
                id="openClassModalButton"
            >
                + Create Class
            </button>

        </div>

        <!-- CLASS GRID -->
        <div class="classCardsGrid">
        
            <div class="classCardContainer">
                <div class="classCardTopDecoration"></div>
                <div class="classStudentCountBadge">2 students</div>
                <h2 class="classCardTitle">Grade 10 - A</h2>
                <p class="classCardSectionText">Section A</p>
                <p class="classCardInfo">Capacity: 40</p>
                <p class="classCardInfo">Room: 101</p>
                <div class="classCardDivider"></div>
            </div>
            
        </div>
    </div>
    
    <!-- <div class="classCardContainer">

                <div class="classCardTopDecoration"></div>

                <div class="classStudentCountBadge">
                    1 students
                </div>

                <h2 class="classCardTitle">
                    Grade 10 - B
                </h2>

                <p class="classCardSectionText">
                    Section B
                </p>

                <p class="classCardInfo">
                    Capacity: 38
                </p>

                <p class="classCardInfo">
                    Room: 102
                </p>

                <div class="classCardDivider"></div>

                <button class="classDeleteButton">
                    🗑
                </button>

            </div> -->

    <!-- =========================
         CREATE CLASS MODAL
    ========================== -->

    <div class="classModalOverlay" id="classModal">

        <div class="classModalContainer">

            <!-- HEADER -->

            <div class="classModalHeader">

                <h2 class="classModalTitle">
                    Create Class
                </h2>

                <button 
                    class="classCloseModalButton"
                    id="closeClassModalButton"
                >
                    ×
                </button>

            </div>

            <!-- FORM -->

            <form>

                <div class="classFormGrid">
                    <div class="classFormGroup">
                        <label class="classFormLabel">CLASS NAME *</label>
                        <input type="text" placeholder="Grade 10 - A" class="classFormInput">
                    </div>

                    <div class="classFormGroup">
                        <label class="classFormLabel">SECTION</label>
                        <input type="text" placeholder="A" class="classFormInput">
                    </div>

                    <div class="classFormGroup">
                        <label class="classFormLabel">CAPACITY</label>

                        <input type="number" placeholder="40" class="classFormInput">

                    </div>
                    <div class="classFormGroup">
                        <label class="classFormLabel">ROOM NUMBER</label>
                        <input type="text" placeholder="101" class="classFormInput">
                    </div>
                </div>

                <!-- FOOTER -->

                <div class="classModalFooter">

                    <button 
                        type="button"
                        class="classCancelButton"
                        id="cancelClassModalButton"
                    >
                        Cancel
                    </button>

                    <button 
                        type="submit"
                        class="classSaveButton"
                    >
                        Create Class
                    </button>

                </div>

            </form>

        </div>

    </div>

    <!-- =========================
         JAVASCRIPT
    ========================== -->
    <script type="text/javascript" src="addclasses.js"></script>
</body>

</html>