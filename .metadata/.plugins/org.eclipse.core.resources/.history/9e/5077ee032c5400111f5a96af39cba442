<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Attendance UI</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:'Poppins',sans-serif;
        }

        body{
            background:#f4f5fb;
            color:#111827;
            display: flex;
            flex-direction: row;
            justify-content: space-between;
            align-items: start;
        }

        /* =========================
           TOPBAR
        ========================== */

        .attendanceTopbar{
            width:100%;
            background:#ffffff;
            padding:12px 28px;
            display:flex;
            justify-content:space-between;
            align-items:center;
            border-bottom:1px solid #e7e7e7;
        }

        .attendanceTopbarTitle{
            font-size:20px;
            font-weight:600;
        }

        .attendanceAdminProfile{
            display:flex;
            align-items:center;
            gap:12px;
            background:#f5f6fb;
            padding:10px 14px;
            border-radius:16px;
        }

        .attendanceAdminAvatar{
            width:42px;
            height:42px;
            border-radius:50%;
            background:linear-gradient(to right,#675cff,#1dd5c8);
            display:flex;
            align-items:center;
            justify-content:center;
            color:#ffffff;
            font-weight:600;
        }

        .attendanceAdminRole{
            font-size:13px;
            color:#8c8c8c;
        }

        /* =========================
           PAGE CONTAINER
        ========================== */

        .attendancePageContainer{
            padding:10px 32px;
            width: 80%;
        }

        .attendancePageHeader{
            display:flex;
            justify-content:space-between;
            align-items:center;
            margin-bottom:30px;
        }

        .attendancePageHeading{
            font-size:44px;
            font-weight:700;
        }

        .attendancePageSubtitle{
            color:#667085;
            margin-top:4px;
        }

        /* =========================
           REFRESH BUTTON
        ========================== */

        .attendanceRefreshButton{
            border:none;
            background:#ffffff;
            padding:14px 28px;
            border-radius:14px;
            font-size:18px;
            font-weight:600;
            cursor:pointer;
            border:1px solid #e2e5ef;
            color:#667085;
            transition:0.3s;
        }

        .attendanceRefreshButton:hover{
            background:#f5f6fb;
        }

        /* =========================
           STATS GRID
        ========================== */

        .attendanceStatsGrid{
            display:grid;
            grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
            gap:20px;
            margin-bottom:32px;
        }

        /* =========================
           STAT CARD
        ========================== */

        .attendanceStatCard{
            background:#ffffff;
            border-radius:28px;
            padding:24px;
            display:flex;
            align-items:center;
            gap:18px;
            position:relative;
            overflow:hidden;
            border:1px solid #ececec;
        }

        .attendanceStatCard::before{
            content:"";
            position:absolute;
            left:0;
            top:0;
            width:5px;
            height:100%;
        }

        .attendancePresentCard::before{
            background:#00d09c;
        }

        .attendanceAbsentCard::before{
            background:#ff5a5f;
        }

        .attendanceLateCard::before{
            background:#ffae00;
        }

        .attendanceAverageCard::before{
            background:#675cff;
        }

        /* =========================
           ICON BOX
        ========================== */

        .attendanceIconBox{
            width:60px;
            height:60px;
            border-radius:16px;
            display:flex;
            align-items:center;
            justify-content:center;
            font-size:24px;
        }

        .attendancePresentIcon{
            background:#dcfff6;
            color:#00c896;
        }

        .attendanceAbsentIcon{
            background:#ffe3e3;
            color:#ff5a5f;
        }

        .attendanceLateIcon{
            background:#fff2db;
            color:#ff9800;
        }

        .attendanceAverageIcon{
            background:#ecebff;
            color:#675cff;
        }

        /* =========================
           STAT TEXT
        ========================== */

        .attendanceStatLabel{
            font-size:15px;
            font-weight:600;
            color:#667085;
            margin-bottom:6px;
        }

        .attendanceStatNumber{
            font-size:48px;
            font-weight:700;
            line-height:1;
        }

        /* =========================
           TABLE CARD
        ========================== */

        .attendanceTableCard{
            background:#ffffff;
            border-radius:30px;
            overflow-y:scroll;
            height: 400px;
            border:1px solid #ececec;
        }

        /* =========================
           TABLE
        ========================== */

        .attendanceDataTable{
            width:100%;
            border-collapse:collapse;
        }

        .attendanceDataTable thead{
            background:#f5f6fb;
        }

        .attendanceDataTable th{
            text-align:left;
            padding:10px 22px;
            font-size:13px;
            color:#98a2b3;
            font-weight:600;
        }

        .attendanceDataTable td{
            padding:12px;
            border-top:1px solid #ececec;
            font-size:16px;
        }

        .attendanceStudentName{
            font-weight:600;
        }

        /* =========================
           STATUS BADGES
        ========================== */

        .attendanceStatusBadge{
            display:inline-block;
            padding:7px 14px;
            border-radius:30px;
            font-size:14px;
            font-weight:600;
        }

        .attendancePresentBadge{
            background:#dcfff6;
            color:#00c896;
        }

        .attendanceAbsentBadge{
            background:#ffe3e3;
            color:#ff5a5f;
        }

        .attendanceLateBadge{
            background:#fff2db;
            color:#ff9800;
        }

        /* =========================
           RESPONSIVE
        ========================== */

        @media(max-width:768px){

            .attendancePageHeader{
                flex-direction:column;
                align-items:flex-start;
                gap:20px;
            }

            .attendanceDataTable{
                display:block;
                overflow-x:auto;
            }

        }

    </style>

</head>

