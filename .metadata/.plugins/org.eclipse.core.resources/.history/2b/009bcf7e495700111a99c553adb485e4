<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Login Page</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:'Poppins',sans-serif;
        }

        body{
            width:100%;
            height:100vh;
            background:#f4f5fb;
            display:flex;
            justify-content:center;
            align-items:center;
            overflow:hidden;
        }

        /* =========================
           LOGIN CARD
        ========================== */

        .loginPageCard{
            width:430px;
            background:#ffffff;
            border-radius:34px;
            padding:42px;
            border:1px solid #ececec;
            box-shadow:0 20px 40px rgba(0,0,0,0.06);
            position:relative;
            overflow:hidden;
        }

        .loginPageCard::before{
            content:"";
            position:absolute;
            top:0;
            left:0;
            width:100%;
            height:6px;
            background:linear-gradient(
                to right,
                #675cff,
                #22d3c5
            );
        }

        /* =========================
           HEADER
        ========================== */

        .loginPageHeader{
            text-align:center;
            margin-bottom:34px;
        }

        .loginPageLogo{
            width:80px;
            height:80px;
            border-radius:24px;
            background:linear-gradient(
                to right,
                #675cff,
                #22d3c5
            );
            display:flex;
            justify-content:center;
            align-items:center;
            margin:0 auto 20px;
            color:#ffffff;
            font-size:32px;
            font-weight:700;
            box-shadow:0 12px 24px rgba(103,92,255,0.25);
        }

        .loginPageTitle{
            font-size:36px;
            font-weight:700;
            color:#111827;
            margin-bottom:8px;
        }

        .loginPageSubtitle{
            color:#667085;
            font-size:15px;
        }

        /* =========================
           FORM
        ========================== */

        .loginPageForm{
            display:flex;
            flex-direction:column;
            gap:22px;
        }

        .loginPageInputGroup{
            display:flex;
            flex-direction:column;
        }

        .loginPageInputLabel{
            margin-bottom:10px;
            font-size:14px;
            font-weight:600;
            color:#667085;
        }

        .loginPageInputField{
            width:100%;
            height:58px;
            border:none;
            outline:none;
            background:#f5f6fb;
            border-radius:16px;
            padding:0 18px;
            font-size:16px;
            border:1px solid #e2e5ef;
            color:#111827;
        }

        .loginPageInputField:focus{
            border-color:#675cff;
        }

        /* =========================
           PASSWORD FIELD
        ========================== */

        .loginPagePasswordWrapper{
            position:relative;
        }

        .loginPagePasswordInput{
            width:100%;
            height:58px;
            border:none;
            outline:none;
            background:#f5f6fb;
            border-radius:16px;
            padding:0 55px 0 18px;
            font-size:16px;
            border:1px solid #e2e5ef;
            color:#111827;
        }

        .loginPagePasswordInput:focus{
            border-color:#675cff;
        }

        .loginPagePasswordToggle{
            position:absolute;
            right:18px;
            top:50%;
            transform:translateY(-50%);
            cursor:pointer;
            font-size:20px;
            color:#667085;
            user-select:none;
        }

        /* =========================
           OPTIONS
        ========================== */

        .loginPageOptions{
            display:flex;
            justify-content:space-between;
            align-items:center;
            margin-top:-4px;
        }

        .loginPageRememberMe{
            display:flex;
            align-items:center;
            gap:8px;
            color:#667085;
            font-size:14px;
        }

        .loginPageForgotPassword{
            text-decoration:none;
            color:#675cff;
            font-size:14px;
            font-weight:600;
        }

        /* =========================
           LOGIN BUTTON
        ========================== */

        .loginPageButton{
            width:100%;
            height:58px;
            border:none;
            border-radius:16px;
            background:linear-gradient(
                to right,
                #675cff,
                #5b4df7
            );
            color:#ffffff;
            font-size:17px;
            font-weight:600;
            cursor:pointer;
            transition:0.3s;
            box-shadow:0 12px 24px rgba(103,92,255,0.25);
        }

        .loginPageButton:hover{
            transform:translateY(-2px);
        }

        /* =========================
           FOOTER
        ========================== */

        .loginPageFooter{
            margin-top:28px;
            text-align:center;
            color:#667085;
            font-size:14px;
        }

        .loginPageFooter a{
            color:#675cff;
            text-decoration:none;
            font-weight:600;
        }

        /* =========================
           RESPONSIVE
        ========================== */

        @media(max-width:500px){

            .loginPageCard{
                width:92%;
                padding:30px;
            }

            .loginPageTitle{
                font-size:30px;
            }

        }

    </style>

</head>

<body>

    <!-- =========================
         LOGIN CARD
    ========================== -->

    <div class="loginPageCard">

        <!-- HEADER -->

        <div class="loginPageHeader">

            <div class="loginPageLogo">
                S
            </div>

            <h1 class="loginPageTitle">
                Welcome Back
            </h1>

            <p class="loginPageSubtitle">
                Login to continue to your dashboard
            </p>

        </div>

        <!-- FORM -->

        <form class="loginPageForm">

            <!-- EMAIL -->

            <div class="loginPageInputGroup">

                <label class="loginPageInputLabel">
                    EMAIL ADDRESS
                </label>

                <input 
                    type="email"
                    placeholder="Enter your email"
                    class="loginPageInputField"
                    id="loginEmail"
                >

            </div>

            <!-- PASSWORD -->

            <div class="loginPageInputGroup">

                <label class="loginPageInputLabel">
                    PASSWORD
                </label>

                <div class="loginPagePasswordWrapper">

                    <input 
                        type="password"
                        placeholder="Enter your password"
                        class="loginPagePasswordInput"
                        id="loginPassword"
                    >

                    <span 
                        class="loginPagePasswordToggle"
                        id="togglePasswordButton"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512"><!--!Font Awesome Free v7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path d="M288 32c-80.8 0-145.5 36.8-192.6 80.6-46.8 43.5-78.1 95.4-93 131.1-3.3 7.9-3.3 16.7 0 24.6 14.9 35.7 46.2 87.7 93 131.1 47.1 43.7 111.8 80.6 192.6 80.6s145.5-36.8 192.6-80.6c46.8-43.5 78.1-95.4 93-131.1 3.3-7.9 3.3-16.7 0-24.6-14.9-35.7-46.2-87.7-93-131.1-47.1-43.7-111.8-80.6-192.6-80.6zM144 256a144 144 0 1 1 288 0 144 144 0 1 1 -288 0zm144-64c0 35.3-28.7 64-64 64-11.5 0-22.3-3-31.7-8.4-1 10.9-.1 22.1 2.9 33.2 13.7 51.2 66.4 81.6 117.6 67.9s81.6-66.4 67.9-117.6c-12.2-45.7-55.5-74.8-101.1-70.8 5.3 9.3 8.4 20.1 8.4 31.7z"/></svg>
                    </span>

                </div>

            </div>

       

            <!-- BUTTON -->

            <button 
                type="submit"
                class="loginPageButton"
            >
                Login
            </button>

        </form>

        <!-- FOOTER -->

        <div class="loginPageFooter">

            Don't have an account?

            <a href="#">
                Contact Admin
            </a>

        </div>

    </div>

    <!-- =========================
         JAVASCRIPT
    ========================== -->

    <script>

        const togglePasswordButton =
            document.getElementById(
                "togglePasswordButton"
            );

        const loginPassword =
            document.getElementById(
                "loginPassword"
            );

        togglePasswordButton.addEventListener(
            "click",
            () => {

                if(
                    loginPassword.type === "password"
                ){

                    loginPassword.type = "text";

                    togglePasswordButton.innerHTML =
                        "<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512"><!--!Font Awesome Free v7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path d="M288 32c-80.8 0-145.5 36.8-192.6 80.6-46.8 43.5-78.1 95.4-93 131.1-3.3 7.9-3.3 16.7 0 24.6 14.9 35.7 46.2 87.7 93 131.1 47.1 43.7 111.8 80.6 192.6 80.6s145.5-36.8 192.6-80.6c46.8-43.5 78.1-95.4 93-131.1 3.3-7.9 3.3-16.7 0-24.6-14.9-35.7-46.2-87.7-93-131.1-47.1-43.7-111.8-80.6-192.6-80.6zM144 256a144 144 0 1 1 288 0 144 144 0 1 1 -288 0zm144-64c0 35.3-28.7 64-64 64-11.5 0-22.3-3-31.7-8.4-1 10.9-.1 22.1 2.9 33.2 13.7 51.2 66.4 81.6 117.6 67.9s81.6-66.4 67.9-117.6c-12.2-45.7-55.5-74.8-101.1-70.8 5.3 9.3 8.4 20.1 8.4 31.7z"/></svg>";

                }

                else{

                    loginPassword.type = "password";

                    togglePasswordButton.innerHTML =
                        "<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512"><!--!Font Awesome Free v7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path d="M41-24.9c-9.4-9.4-24.6-9.4-33.9 0S-2.3-.3 7 9.1l528 528c9.4 9.4 24.6 9.4 33.9 0s9.4-24.6 0-33.9l-96.4-96.4c2.7-2.4 5.4-4.8 8-7.2 46.8-43.5 78.1-95.4 93-131.1 3.3-7.9 3.3-16.7 0-24.6-14.9-35.7-46.2-87.7-93-131.1-47.1-43.7-111.8-80.6-192.6-80.6-56.8 0-105.6 18.2-146 44.2L41-24.9zM204.5 138.7c23.5-16.8 52.4-26.7 83.5-26.7 79.5 0 144 64.5 144 144 0 31.1-9.9 59.9-26.7 83.5l-34.7-34.7c12.7-21.4 17-47.7 10.1-73.7-13.7-51.2-66.4-81.6-117.6-67.9-8.6 2.3-16.7 5.7-24 10l-34.7-34.7zM325.3 395.1c-11.9 3.2-24.4 4.9-37.3 4.9-79.5 0-144-64.5-144-144 0-12.9 1.7-25.4 4.9-37.3L69.4 139.2c-32.6 36.8-55 75.8-66.9 104.5-3.3 7.9-3.3 16.7 0 24.6 14.9 35.7 46.2 87.7 93 131.1 47.1 43.7 111.8 80.6 192.6 80.6 37.3 0 71.2-7.9 101.5-20.6l-64.2-64.2z"/></svg>";

                }

            }
        );

    </script>

</body>

