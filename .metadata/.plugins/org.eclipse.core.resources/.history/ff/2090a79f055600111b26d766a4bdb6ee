package com.sms;

import jakarta.servlet.ServletException;
import jakarta.servlet.annotation.WebServlet;
import jakarta.servlet.http.HttpServlet;
import jakarta.servlet.http.HttpServletRequest;
import jakarta.servlet.http.HttpServletResponse;

import java.io.BufferedReader;
import java.io.IOException;
import java.io.PrintWriter;
import java.sql.Connection;
import java.sql.PreparedStatement;

import org.json.JSONObject;

@WebServlet("/AddClasses")
public class AddClasses extends HttpServlet {
	private static final long serialVersionUID = 1L;

	public AddClasses() {
		super();

	}

	protected void doGet(HttpServletRequest request, HttpServletResponse response)
			throws ServletException, IOException {

	}

	protected void doPost(HttpServletRequest request, HttpServletResponse response)
			throws ServletException, IOException {

		StringBuilder sb = new StringBuilder();

		BufferedReader reader = request.getReader();

		String line;

		while ((line = reader.readLine()) != null) {
			sb.append(line);
		}

		JSONObject json = new JSONObject(sb.toString());

		String className = json.getString("className");
		String section = json.getString("section");
		int capacity = json.getInt("capacity");
		String roomNumber = json.getString("roomNumber");

		response.setContentType("application/json");

		PrintWriter out = response.getWriter();

		try {

			Connection con = DBConnection.getConnection();

			String query = "INSERT INTO classes(class_name, section, capacity, room_number) VALUES(?,?,?,?)";

			PreparedStatement ps = con.prepareStatement(query);

			ps.setString(1, className);
			ps.setString(2, section);
			ps.setInt(3, capacity);
			ps.setString(4, roomNumber);

			int rows = ps.executeUpdate();

			if (rows > 0) {
				out.print("{\"message\":\"Class Added Successfully\"}");
			} else {
				out.print("{\"message\":\"Failed to Add Class\"}");
			}
		} catch (Exception e) {
			e.printStackTrace();
			out.print("{\"message\":\"Error Occurred\"}");
		}
	}

}
