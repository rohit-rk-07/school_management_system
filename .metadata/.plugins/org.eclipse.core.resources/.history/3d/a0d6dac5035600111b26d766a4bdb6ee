/**
 * 
 */<script>

       const classModal = document.getElementById(
           "classModal"
       );

       const openClassModalButton = document.getElementById(
           "openClassModalButton"
       );

       const closeClassModalButton = document.getElementById(
           "closeClassModalButton"
       );

       const cancelClassModalButton = document.getElementById(
           "cancelClassModalButton"
       );

       // OPEN MODAL

       openClassModalButton.addEventListener("click", () => {

           classModal.classList.add("active");

       });

       // CLOSE MODAL

       closeClassModalButton.addEventListener("click", () => {

           classModal.classList.remove("active");

       });

       cancelClassModalButton.addEventListener("click", () => {

           classModal.classList.remove("active");

       });

       // CLOSE ON OUTSIDE CLICK

       classModal.addEventListener("click", (event) => {

           if(event.target === classModal){

               classModal.classList.remove("active");

           }

       });

   </script>
